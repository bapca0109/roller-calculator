{
  "meta": {
    "version": "1.0",
    "last_updated": "2024-05-20",
    "description": "Design guidelines for Belt Conveyor Rollers Engineering App"
  },
  "design_philosophy": {
    "archetype": "The Performance Pro",
    "core_values": [
      "Precision",
      "Reliability",
      "Industrial Clarity",
      "Minimalist Professionalism"
    ],
    "visual_direction": "High-contrast, data-dense but readable, card-based layouts with distinct hierarchy. Uses Carmine Red for primary actions and Dark Slate for structure."
  },
  "theme": {
    "colors": {
      "primary": {
        "main": "#960018",
        "light": "#C41E3A",
        "dark": "#750012",
        "bg_soft": "#FFF5F5",
        "contrast_text": "#FFFFFF"
      },
      "secondary": {
        "main": "#0F172A",
        "light": "#334155",
        "dark": "#020617",
        "contrast_text": "#FFFFFF"
      },
      "neutral": {
        "white": "#FFFFFF",
        "background": "#F8FAFC",
        "surface": "#FFFFFF",
        "border": "#E2E8F0",
        "border_strong": "#CBD5E1",
        "text_primary": "#0F172A",
        "text_secondary": "#64748B",
        "text_tertiary": "#94A3B8"
      },
      "semantic": {
        "success": "#10B981",
        "success_bg": "#ECFDF5",
        "warning": "#F59E0B",
        "warning_bg": "#FFFBEB",
        "error": "#EF4444",
        "error_bg": "#FEF2F2",
        "info": "#3B82F6",
        "info_bg": "#EFF6FF"
      }
    },
    "typography": {
      "font_family": "System (San Francisco / Roboto)",
      "weights": {
        "regular": "400",
        "medium": "500",
        "semibold": "600",
        "bold": "700"
      },
      "sizes": {
        "h1": { "fontSize": 28, "lineHeight": 34, "fontWeight": "700" },
        "h2": { "fontSize": 24, "lineHeight": 30, "fontWeight": "600" },
        "h3": { "fontSize": 20, "lineHeight": 28, "fontWeight": "600" },
        "subtitle1": { "fontSize": 18, "lineHeight": 26, "fontWeight": "600" },
        "subtitle2": { "fontSize": 16, "lineHeight": 24, "fontWeight": "500" },
        "body1": { "fontSize": 16, "lineHeight": 24, "fontWeight": "400" },
        "body2": { "fontSize": 14, "lineHeight": 20, "fontWeight": "400" },
        "caption": { "fontSize": 12, "lineHeight": 16, "fontWeight": "400" },
        "overline": { "fontSize": 10, "lineHeight": 16, "fontWeight": "600", "textTransform": "uppercase", "letterSpacing": 1 }
      }
    },
    "spacing": {
      "xs": 4,
      "s": 8,
      "m": 12,
      "l": 16,
      "xl": 24,
      "xxl": 32,
      "section": 48
    },
    "borderRadius": {
      "s": 4,
      "m": 8,
      "l": 12,
      "xl": 16,
      "round": 9999
    },
    "shadows": {
      "card": {
        "shadowColor": "#0F172A",
        "shadowOffset": { "width": 0, "height": 2 },
        "shadowOpacity": 0.05,
        "shadowRadius": 8,
        "elevation": 2
      },
      "card_hover": {
        "shadowColor": "#0F172A",
        "shadowOffset": { "width": 0, "height": 4 },
        "shadowOpacity": 0.1,
        "shadowRadius": 12,
        "elevation": 4
      },
      "modal": {
        "shadowColor": "#0F172A",
        "shadowOffset": { "width": 0, "height": 8 },
        "shadowOpacity": 0.15,
        "shadowRadius": 24,
        "elevation": 12
      }
    }
  },
  "ui_components": {
    "buttons": {
      "primary": {
        "style": {
          "backgroundColor": "#960018",
          "borderRadius": 8,
          "paddingVertical": 12,
          "paddingHorizontal": 20,
          "alignItems": "center",
          "justifyContent": "center",
          "flexDirection": "row",
          "elevation": 2
        },
        "textStyle": {
          "color": "#FFFFFF",
          "fontSize": 16,
          "fontWeight": "600",
          "letterSpacing": 0.5
        }
      },
      "secondary": {
        "style": {
          "backgroundColor": "#FFFFFF",
          "borderRadius": 8,
          "borderWidth": 1,
          "borderColor": "#E2E8F0",
          "paddingVertical": 12,
          "paddingHorizontal": 20,
          "alignItems": "center",
          "justifyContent": "center",
          "flexDirection": "row"
        },
        "textStyle": {
          "color": "#0F172A",
          "fontSize": 16,
          "fontWeight": "500"
        }
      },
      "ghost": {
        "style": {
          "backgroundColor": "transparent",
          "paddingVertical": 8,
          "paddingHorizontal": 12
        },
        "textStyle": {
          "color": "#64748B",
          "fontSize": 14,
          "fontWeight": "500"
        }
      },
      "danger": {
        "style": {
          "backgroundColor": "#FEF2F2",
          "borderRadius": 8,
          "borderWidth": 1,
          "borderColor": "#FECACA",
          "paddingVertical": 12,
          "paddingHorizontal": 20
        },
        "textStyle": {
          "color": "#EF4444",
          "fontSize": 16,
          "fontWeight": "600"
        }
      }
    },
    "inputs": {
      "container": {
        "marginBottom": 16
      },
      "label": {
        "fontSize": 14,
        "fontWeight": "500",
        "color": "#475569",
        "marginBottom": 6
      },
      "field": {
        "backgroundColor": "#FFFFFF",
        "borderWidth": 1,
        "borderColor": "#E2E8F0",
        "borderRadius": 8,
        "paddingHorizontal": 12,
        "paddingVertical": 10,
        "fontSize": 15,
        "color": "#0F172A",
        "height": 44
      },
      "field_focus": {
        "borderColor": "#960018",
        "borderWidth": 1.5
      },
      "field_error": {
        "borderColor": "#EF4444",
        "backgroundColor": "#FEF2F2"
      }
    },
    "cards": {
      "container": {
        "backgroundColor": "#FFFFFF",
        "borderRadius": 12,
        "padding": 16,
        "marginBottom": 12,
        "borderWidth": 1,
        "borderColor": "#F1F5F9",
        "shadowColor": "#0F172A",
        "shadowOffset": { "width": 0, "height": 1 },
        "shadowOpacity": 0.05,
        "shadowRadius": 2,
        "elevation": 2
      },
      "header": {
        "flexDirection": "row",
        "justifyContent": "space-between",
        "alignItems": "center",
        "marginBottom": 12,
        "paddingBottom": 12,
        "borderBottomWidth": 1,
        "borderBottomColor": "#F1F5F9"
      }
    },
    "tabs": {
      "container": {
        "flexDirection": "row",
        "backgroundColor": "#F8FAFC",
        "padding": 4,
        "borderRadius": 12,
        "marginHorizontal": 16,
        "marginVertical": 12,
        "borderWidth": 1,
        "borderColor": "#E2E8F0"
      },
      "item": {
        "flex": 1,
        "paddingVertical": 8,
        "alignItems": "center",
        "borderRadius": 8
      },
      "item_active": {
        "backgroundColor": "#FFFFFF",
        "shadowColor": "#000",
        "shadowOffset": { "width": 0, "height": 1 },
        "shadowOpacity": 0.05,
        "shadowRadius": 2,
        "elevation": 1
      },
      "text": {
        "fontSize": 14,
        "fontWeight": "500",
        "color": "#64748B"
      },
      "text_active": {
        "color": "#960018",
        "fontWeight": "600"
      }
    }
  },
  "screens": {
    "Calculator": {
      "layout": {
        "padding": 16,
        "backgroundColor": "#F8FAFC"
      },
      "section_header": {
        "fontSize": 18,
        "fontWeight": "600",
        "color": "#0F172A",
        "marginTop": 24,
        "marginBottom": 12
      },
      "result_card": {
        "backgroundColor": "#0F172A",
        "borderRadius": 16,
        "padding": 20,
        "marginTop": 24
      },
      "result_value": {
        "fontSize": 32,
        "fontWeight": "700",
        "color": "#FFFFFF",
        "marginVertical": 8
      }
    },
    "Quotes": {
      "list_container": {
        "padding": 16,
        "paddingBottom": 100
      },
      "status_badge": {
        "pending": { "backgroundColor": "#FFF7ED", "color": "#C2410C" },
        "approved": { "backgroundColor": "#ECFDF5", "color": "#047857" },
        "rejected": { "backgroundColor": "#FEF2F2", "color": "#B91C1C" }
      }
    }
  },
  "asset_updates": {
    "images": [
      {
        "category": "hero",
        "description": "Clean industrial warehouse or conveyor belt detail",
        "url": "https://images.unsplash.com/photo-1748946469988-61310d7ea26a?crop=entropy&cs=srgb&fm=jpg&ixid=M3w3NDQ2NDN8MHwxfHNlYXJjaHwyfHxtb2Rlcm4lMjBmYWN0b3J5JTIwY29udmV5b3IlMjBiZWx0JTIwc3lzdGVtJTIwY2xlYW58ZW58MHx8fHwxNzczMDc3MzQyfDA&ixlib=rb-4.1.0&q=85"
      },
      {
        "category": "empty_state",
        "description": "Minimal abstract blueprint",
        "url": "https://images.unsplash.com/photo-1727522974676-c2f9c32ee692?crop=entropy&cs=srgb&fm=jpg&ixid=M3w4NjY2NzV8MHwxfHNlYXJjaHw0fHxhYnN0cmFjdCUyMGluZHVzdHJpYWwlMjBibHVlcHJpbnRzJTIwdGVjaG5pY2FsJTIwZHJhd2luZ3xlbnwwfHx8fDE3NzMwNzczNDV8MA&ixlib=rb-4.1.0&q=85"
      }
    ]
  },
  "instructions_to_main_agent": [
    "Do NOT rewrite entire files. Use 'search_replace' or specific 'insert_text' where possible to avoid context loss in large files.",
    "Prioritize updating the 'theme/index.ts' first to match the new color palette.",
    "For 'Calculator.tsx' and 'Quotes.tsx', focus on updating the 'StyleSheet.create' styles to match the 'ui_components' specs defined in this JSON.",
    "Ensure 'data-testid' is added to all TouchableOpacity/Pressable elements for testing."
  ],
  "UNIVERSAL_GUIDELINES": [
    "Use 'flex: 1' for main containers to ensure full height.",
    "Avoid hardcoded dimensions (width/height) unless absolutely necessary for icons/images.",
    "Use 'KeyboardAvoidingView' for all form screens.",
    "Ensure 44px minimum touch target size for buttons."
  ]
}