{
  "cli": {
    "version": ">= 3.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "withoutCredentials": true
      },
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_BACKEND_URL": "https://conveyor-roller-calc-1.preview.emergentagent.com",
        "EXPO_PUBLIC_PINCODE_API_URL": "https://api.postalpincode.in"
      }
    },
    "production": {
      "distribution": "store",
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {
        "autoIncrement": true
      },
      "env": {
        "EXPO_PUBLIC_BACKEND_URL": "https://conveyor-roller-calc-1.preview.emergentagent.com",
        "EXPO_PUBLIC_PINCODE_API_URL": "https://api.postalpincode.in"
      }
    }
  }
}
