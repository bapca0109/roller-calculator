{
  "cli": {
    "version": ">= 3.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "node": "18.18.0"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "withoutCredentials": true
      },
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_BACKEND_URL": "https://rfq-hub-4.preview.emergentagent.com",
        "EXPO_PUBLIC_PINCODE_API_URL": "https://api.postalpincode.in"
      },
      "node": "18.18.0",
      "yarn": {
        "version": "1.22.22"
      }
    },
    "production": {
      "distribution": "store",
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {
        "autoIncrement": true
      },
      "env": {
        "EXPO_PUBLIC_BACKEND_URL": "https://rfq-hub-4.preview.emergentagent.com",
        "EXPO_PUBLIC_PINCODE_API_URL": "https://api.postalpincode.in"
      },
      "node": "18.18.0",
      "yarn": {
        "version": "1.22.22"
      }
    }
  }
}
